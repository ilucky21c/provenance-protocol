{
  "name": "provenance-protocol",
  "version": "0.1.3",
  "description": "SDK for querying the Provenance agent identity index",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./keygen": {
      "types": "./src/keygen.d.ts",
      "import": "./src/keygen.js"
    }
  },
  "files": [
    "src/index.js",
    "src/index.d.ts",
    "src/keygen.js",
    "src/keygen.d.ts",
    "README.md"
  ],
  "keywords": [
    "ai-agent",
    "agent-identity",
    "provenance",
    "trust",
    "llm",
    "verification"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ilucky21c/provenance-protocol"
  },
  "homepage": "https://getprovenance.dev",
  "engines": {
    "node": ">=14.0.0"
  }
}
